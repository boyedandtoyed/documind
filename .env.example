# Ollama runs on the host, outside Docker.
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=gemma4:26b
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# Qdrant
QDRANT_URL=http://qdrant:6333
COLLECTION_NAME=documind

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=documind123

# Search tuning
TOP_K=10
RERANK_TOP_K=5
HYBRID_ALPHA=0.7

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Storage
DB_PATH=/data/documind.db
UPLOAD_DIR=/data/uploads

# Frontend/API
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","https://documind.binodtiwari.com"]

# App
DEBUG=false
